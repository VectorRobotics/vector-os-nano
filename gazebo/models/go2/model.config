<?xml version="1.0" ?>
<model>
  <name>Go2 Quadruped</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Vector Robotics</name>
    <email>team@vectorrobotics.ai</email>
  </author>
  <description>
    Unitree Go2 quadruped robot for Gazebo Harmonic.
    12 DOF (4 legs x hip/thigh/calf), Livox MID-360 lidar,
    Intel RealSense D435 RGB+depth cameras, IMU.
    Simple box/cylinder geometry — meshes addable later.
  </description>
</model>
