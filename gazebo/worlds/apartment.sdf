<?xml version="1.0" ?>
<!--
  apartment.sdf — Furnished apartment world for Gazebo Harmonic (SDF 1.9)

  Five-room apartment for navigation testing and VLN development.
  The Go2 quadruped explores rooms, identifies them by contents, and grasps objects.

  Floor plan (all coordinates in metres, origin at hallway centre):
  ┌──────────────┬───────────┬──────────┐
  │              │           │          │
  │  Bedroom     D  Hallway  D Kitchen  │
  │  (carpet)    │           │ (tile)   │
  │  4x3m        │  2x6m     │ 3x3m    │
  ├──────D───────┤           ├────D─────┤
  │              │           │          │
  │  Bathroom    │           │  Living  │
  │  (tile)      │           │  Room    │
  │  2.5x3m      │           │ 4x4m    │
  │              │           │ (wood)   │
  └──────────────┴───────────┴──────────┘

  Room boundaries (inner face, 0.15 m walls):
    Hallway      x=[-1,  1],  y=[-3, 3]
    Living Room  x=[ 1,  6],  y=[-3, 0]
    Kitchen      x=[ 1,  6],  y=[ 0, 3]
    Bedroom      x=[-6, -1],  y=[ 0, 3]
    Bathroom     x=[-4, -1],  y=[-3, 0]

  Door openings (0.9 m gap, no door model):
    D1: Hallway ↔ Living Room  — east hallway wall at x=1,  y≈-1.5
    D2: Hallway ↔ Kitchen      — east hallway wall at x=1,  y≈ 1.5
    D3: Hallway ↔ Bedroom      — west hallway wall at x=-1, y≈ 1.5
    D4: Hallway ↔ Bathroom     — west hallway wall at x=-1, y≈-1.5

  All walls: 0.15 m thick, 2.5 m tall.
  Wall material: painted drywall #E8E8E8 (ambient 0.91 0.91 0.91).

  Floor materials (distinct so VLM can identify rooms):
    Hallway     — light gray    #D8D8D8  (0.85 0.85 0.85)
    Living Room — warm wood     #8B6F47  (0.55 0.44 0.28)
    Kitchen     — white tile    #F0F0F0  (0.94 0.94 0.94)
    Bedroom     — beige carpet  #D4C5A9  (0.83 0.77 0.66)
    Bathroom    — light blue    #D0E8F0  (0.82 0.91 0.94)
-->
<sdf version="1.9">
  <world name="apartment">

    <!-- Physics: 1 ms fixed step, DART solver -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Gravity -->
    <gravity>0 0 -9.81</gravity>

    <!-- Required Gazebo Harmonic system plugins -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-contact-system"
            name="gz::sim::systems::Contact"/>

    <!-- ==================== GLOBAL LIGHTING ==================== -->

    <!-- Sun: primary directional light -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Per-room point lights at ceiling height z=2.3 m -->
    <!-- Hallway ceiling lamp -->
    <light type="point" name="light_hallway">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 2.3 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Living room ceiling lamp -->
    <light type="point" name="light_living_room">
      <cast_shadows>false</cast_shadows>
      <pose>3.5 -1.5 2.3 0 0 0</pose>
      <diffuse>0.9 0.85 0.75 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Kitchen ceiling lamp -->
    <light type="point" name="light_kitchen">
      <cast_shadows>false</cast_shadows>
      <pose>3.5 1.5 2.3 0 0 0</pose>
      <diffuse>1.0 1.0 0.95 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Bedroom ceiling lamp -->
    <light type="point" name="light_bedroom">
      <cast_shadows>false</cast_shadows>
      <pose>-3.5 1.5 2.3 0 0 0</pose>
      <diffuse>0.85 0.85 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Bathroom ceiling lamp -->
    <light type="point" name="light_bathroom">
      <cast_shadows>false</cast_shadows>
      <pose>-2.5 -1.5 2.3 0 0 0</pose>
      <diffuse>0.95 0.98 1.0 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>6</range>
        <constant>0.5</constant>
        <linear>0.02</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- ==================== HALLWAY ==================== -->
    <!-- Dimensions: x=[-1,1], y=[-3,3], 2m wide x 6m long -->
    <!-- Floor: light gray #D8D8D8 -->

    <model name="floor_hallway">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>2.0 6.0 0.01</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>2.0 6.0 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hallway north outer wall: y=3, x=[-1,1], 2m wide -->
    <model name="wall_hallway_north">
      <static>true</static>
      <pose>0 3.075 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>2.15 0.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>2.15 0.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hallway south outer wall: y=-3, x=[-1,1], 2m wide -->
    <model name="wall_hallway_south">
      <static>true</static>
      <pose>0 -3.075 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>2.15 0.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>2.15 0.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hallway east wall segments (with D1 at y=-1.5 and D2 at y=1.5) -->
    <!-- D1 gap: y=[-2.0, -1.1]  — 0.9m opening for living room -->
    <!-- D2 gap: y=[ 1.1,  2.0]  — 0.9m opening for kitchen -->
    <!-- East wall south segment: y=[-3, -2.0] -->
    <model name="wall_hallway_east_south">
      <static>true</static>
      <pose>1.075 -2.55 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- East wall middle segment: y=[-1.1, 1.1] — between the two doors -->
    <model name="wall_hallway_east_mid">
      <static>true</static>
      <pose>1.075 0 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 2.2 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 2.2 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- East wall north segment: y=[2.0, 3.0] -->
    <model name="wall_hallway_east_north">
      <static>true</static>
      <pose>1.075 2.55 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Hallway west wall segments (with D3 at y=1.5 and D4 at y=-1.5) -->
    <!-- D4 gap: y=[-2.0, -1.1]  — 0.9m opening for bathroom -->
    <!-- D3 gap: y=[ 1.1,  2.0]  — 0.9m opening for bedroom -->
    <!-- West wall south segment: y=[-3, -2.0] -->
    <model name="wall_hallway_west_south">
      <static>true</static>
      <pose>-1.075 -2.55 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- West wall middle segment: y=[-1.1, 1.1] — between the two doors -->
    <model name="wall_hallway_west_mid">
      <static>true</static>
      <pose>-1.075 0 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 2.2 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 2.2 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- West wall north segment: y=[2.0, 3.0] -->
    <model name="wall_hallway_west_north">
      <static>true</static>
      <pose>-1.075 2.55 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 1.9 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== LIVING ROOM ==================== -->
    <!-- Dimensions: x=[1,6], y=[-3,0], 5m x 3m -->
    <!-- Floor: warm wood #8B6F47 -->

    <model name="floor_living_room">
      <static>true</static>
      <pose>3.5 -1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>5.0 3.0 0.01</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>5.0 3.0 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.55 0.44 0.28 1</ambient>
            <diffuse>0.55 0.44 0.28 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Living room outer east wall: x=6.15, y=[-3,0] -->
    <model name="wall_living_east">
      <static>true</static>
      <pose>6.075 -1.5 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 3.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 3.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Living room outer south wall: y=-3.075, x=[1,6] -->
    <model name="wall_living_south">
      <static>true</static>
      <pose>3.5 -3.075 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>5.15 0.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>5.15 0.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Living room / Kitchen divider wall: y=0.075, x=[1,6] (no door) -->
    <model name="wall_living_kitchen_divider">
      <static>true</static>
      <pose>3.5 0.075 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>5.0 0.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>5.0 0.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== LIVING ROOM FURNITURE ==================== -->

    <!-- Sofa: pos=(4.5, -2.5, 0.4), size=(1.8, 0.8, 0.8), dark gray -->
    <model name="sofa">
      <static>true</static>
      <pose>4.5 -2.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.8 0.8 0.8</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.8 0.8 0.8</size></box>
          </geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Coffee table: pos=(3.5, -1.5, 0.25), size=(0.8, 0.5, 0.5), brown -->
    <model name="coffee_table">
      <static>true</static>
      <pose>3.5 -1.5 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.8 0.5 0.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.8 0.5 0.5</size></box>
          </geometry>
          <material>
            <ambient>0.44 0.27 0.11 1</ambient>
            <diffuse>0.44 0.27 0.11 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bookshelf: pos=(5.0, 0.0, 0.9), size=(0.3, 1.2, 1.8), dark brown -->
    <model name="bookshelf">
      <static>true</static>
      <pose>5.0 -0.2 0.9 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.3 1.2 1.8</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.3 1.2 1.8</size></box>
          </geometry>
          <material>
            <ambient>0.22 0.14 0.06 1</ambient>
            <diffuse>0.22 0.14 0.06 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- TV stand: pos=(2.0, -2.5, 0.3), size=(1.0, 0.3, 0.6), black -->
    <model name="tv_stand">
      <static>true</static>
      <pose>2.0 -2.5 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.0 0.3 0.6</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.0 0.3 0.6</size></box>
          </geometry>
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== KITCHEN ==================== -->
    <!-- Dimensions: x=[1,6], y=[0,3], 5m x 3m -->
    <!-- Floor: white tile #F0F0F0 -->

    <model name="floor_kitchen">
      <static>true</static>
      <pose>3.5 1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>5.0 3.0 0.01</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>5.0 3.0 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.94 0.94 0.94 1</ambient>
            <diffuse>0.94 0.94 0.94 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kitchen outer east wall: x=6.075, y=[0,3] -->
    <model name="wall_kitchen_east">
      <static>true</static>
      <pose>6.075 1.5 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>0.15 3.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>0.15 3.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kitchen outer north wall: y=3.075, x=[1,6] -->
    <model name="wall_kitchen_north">
      <static>true</static>
      <pose>3.5 3.075 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>5.15 0.15 2.5</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>5.15 0.15 2.5</size></box>
          </geometry>
          <material>
            <ambient>0.91 0.91 0.91 1</ambient>
            <diffuse>0.91 0.91 0.91 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== KITCHEN FURNITURE ==================== -->

    <!-- Kitchen table: pos=(3.5, 2.0, 0.38), size=(1.0, 0.6, 0.76), light brown -->
    <model name="kitchen_table">
      <static>true</static>
      <pose>3.5 2.0 0.38 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box><size>1.0 0.6 0.76</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box><size>1.0 0.6 0.76</size></box>
          </geometry>
          <material>
            <ambient>0.72 0.60 0.45 1</ambient>
            <diffuse>0.72 0.60 0.45 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Kitchen chair 1: pos=(3.0, 2.0, 0.22), size=(0.4, 0.4, 0.45), gray -->
    <model name="kitchen_chair_1">
